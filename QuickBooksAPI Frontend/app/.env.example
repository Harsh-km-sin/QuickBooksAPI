# Frontend environment example (Vite)
# Copy to `.env.local` for local development, or set these in Azure Static Web Apps / App Service settings.

# API base URL the frontend should call
VITE_API_URL=https://localhost:7135

# Optional frontend telemetry/logging level used by app code
VITE_LOG_LEVEL=info

# Optional environment label for UI/debug
VITE_APP_ENV=local